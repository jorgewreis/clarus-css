{
  "name": "clarus-css",
  "version": "0.3.1",
  "description": "A modern, minimal CSS framework for building interfaces with HTML, CSS, and vanilla JavaScript.",
  "keywords": [
    "css",
    "framework",
    "ui",
    "frontend",
    "html",
    "vanilla-js",
    "bootstrap"
  ],
  "homepage": "https://github.com/jorgewreis/clarus-css#readme",
  "bugs": {
    "url": "https://github.com/jorgewreis/clarus-css/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorgewreis/clarus-css.git"
  },
  "license": "MIT",
  "author": "Jorge Reis",
  "sideEffects": [
    "*.css",
    "dist/**/*.css",
    "js/*.js",
    "dist/js/*.js"
  ],
  "main": "dist/css/clarus.css",
  "style": "dist/css/clarus.css",
  "unpkg": "dist/css/clarus.min.css",
  "jsdelivr": "dist/css/clarus.min.css",
  "exports": {
    ".": "./dist/css/clarus.css",
    "./scss": "./scss/clarus.scss",
    "./scss/*": "./scss/*",
    "./layout.css": "./dist/css/layout.css",
    "./forms.css": "./dist/css/forms.css",
    "./components.css": "./dist/css/components.css",
    "./helpers.css": "./dist/css/helpers.css",
    "./js": "./dist/js/clarus.js",
    "./js/*": "./js/*.js",
    "./package.json": "./package.json"
  },
  "files": [
    "assets",
    "dist",
    "scss",
    "js",
    "docs/definitions.md",
    "docs/scss-architecture.md",
    "mockup",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && node scripts/build.mjs",
    "watch": "node scripts/watch.mjs",
    "lint:scss": "stylelint \"scss/**/*.scss\"",
    "lint": "npm run lint:scss",
    "test": "vitest run",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "prepublishOnly": "npm run build && npm test"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.5.2",
    "chokidar": "^5.0.0",
    "cssnano": "^8.0.2",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vitest": "^4.1.9"
  }
}
