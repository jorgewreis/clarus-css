    "url": "https://github.com/jorgewreis/clarus-css/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorgewreis/clarus-css.git",
    "directory": "packages/clarus-icons"
  },
  "license": "MIT",
  "author": "Jorge Reis",
  "type": "module",
  "main": "./index.js",
  "exports": {
    ".": "./index.js",
    "./icons/*": "./icons/*.js",
    "./svg/*": "./svg/*",
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": [
